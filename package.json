{
  "name": "f1-predictions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3210",
    "postinstall": "node scripts/generate-pwa-icons.mjs",
    "build": "node scripts/generate-pwa-icons.mjs && next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "electron": "electron .",
    "predist": "node scripts/fetch-cloudflared.mjs",
    "dist": "npm run build && electron-builder",
    "lint": "eslint"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "nl.rubyruben.f1predictions",
    "productName": "F1 Predictions",
    "files": [
      ".next/standalone/**",
      ".next/standalone/.next/static/**",
      "public/**",
      "electron/**"
    ],
    "extraResources": [
      {
        "from": "bin/cloudflared.exe",
        "to": "cloudflared.exe"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
